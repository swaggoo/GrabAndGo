    {
      "title": "HTTP Traffic & Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "title": "Total Requests (Lifetime)",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(http_server_request_duration_seconds_count) by (job)", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "title": "Request Errors (5xx)",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}) by (job) or vector(0)", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "title": "Requests per Second (RPS)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_server_request_duration_seconds_count[5m])) by (job)", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "title": "System Resources",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "title": "GC Heap Size (MB)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(process_runtime_dotnet_gc_objects_size_bytes) by (job) / 1024 / 1024", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "title": "Thread Pool Size",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(process_runtime_dotnet_thread_pool_threads_count) by (job)", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "title": "Logs & Distributed Tracing",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
