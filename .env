# ==========================================
# GRABANDGO INFRASTRUCTURE CONFIGURATION
# ==========================================

# Use 'localhost' for Browser testing
# Use '10.0.2.2' for Android Emulator
# Use your Machine IP (e.g. 192.168.1.5) for real Android Devices
API_HOST=localhost

# Gateway Port
GATEWAY_PORT=5010

# Generated URLs for images will use this base
PUBLIC_BASE_URL=http://${API_HOST}:${GATEWAY_PORT}

# Database Configuration
POSTGRES_PASSWORD=GrabAndGo_Dev123!

# Service Versions
TAG=latest
REGISTRY=grabandgo
